FROM ubuntu:20.04

FROM python:3.9

# Update package lists and install necessary dependencies
RUN apt-get update

# RUN apt-get install -y python3 python3-pip git
WORKDIR /mle_training

# Copy the contents of the source directory
COPY . .

# Install dependencies for building
RUN pip3 install build

# Install python3-venv package
RUN apt-get install -y python3-venv

# Build the package
RUN python3 -m build


# Install MLflow, create the logs directory, and install the package
RUN pip3 install -r requirements.txt && \
    mkdir -p /mle_training/logs


# Run your script and tests
CMD ["sh", "-c", "python3 ./src/housing/run_script.py && pytest && mlflow ui --port 5050"]
